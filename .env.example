# ===== Configuração do Antigravity Telegram Suite =====
# Copie este arquivo para .env e preencha com seus dados.

# Token do Bot do Telegram (pegue com o @BotFather)
BOT_TOKEN=seu_bot_token_aqui

# Seu(s) ID(s) de Chat do Telegram (mande /start para obter)
# Para múltiplos usuários, separe com vírgulas: 123456,789012
ALLOWED_CHAT_ID=

# Portas de Depuração do CDP (devem coincidir com os argumentos de inicialização do IDE)
# Se rodar os dois aplicativos lado a lado, use portas diferentes
AGENT_CDP_PORT=9333
IDE_CDP_PORT=9334

# Modelo de IA padrão ao iniciar um novo chat / inicializar o IDE
DEFAULT_MODEL=Gemini 3.1 Pro (High)

# Idioma: en | tr | de | es | fr | pt-br
LANGUAGE=pt-br

# Opcional: Diretório personalizado de projetos (o padrão é a pasta de projetos)
# PROJECTS_DIR=C:\Caminho\Para\Seus\Projetos

# ===== Configuração do Dual App Antigravity =====
# Aplicativo alvo preferencial ativo: 'agent' (Antigravity Standalone) ou 'ide' (Antigravity IDE)
ANTIGRAVITY_PREFERRED_APP=ide

# Opcional: Caminhos personalizados dos executáveis no Windows
# ANTIGRAVITY_AGENT_PATH=C:\Users\SeuUsuario\AppData\Local\Programs\Antigravity\Antigravity.exe
# ANTIGRAVITY_IDE_PATH=C:\Users\SeuUsuario\AppData\Local\Programs\Antigravity-IDE\Antigravity-IDE.exe

# Habilitar o módulo de auto-aceitação (auto-accept) por padrão quando o bot iniciar
AUTOACCEPT_DEFAULT=true
